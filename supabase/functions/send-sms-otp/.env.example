# ─────────────────────────────────────────────────────────────────────────────
# Variables d'env de l'Edge Function send-sms-otp
# À copier dans Supabase Dashboard → Edge Functions → send-sms-otp → Secrets
# ─────────────────────────────────────────────────────────────────────────────

# Fourni automatiquement par Supabase quand tu actives le hook "Send SMS"
SEND_SMS_HOOK_SECRET=v1,whsec_XXXXXXXXXXXXXXXXXX

# Quel provider utiliser : 'letexto' | 'africastalking' | 'generic'
SMS_PROVIDER=letexto

# Clé API du provider
SMS_API_KEY=ta_cle_api_ici

# Username / app id (utile pour Africa's Talking, ignoré sinon)
SMS_API_USER=

# Sender ID affiché par le SMS (max 11 caractères, lettres + chiffres, sans espaces)
SMS_FROM=MonEglise
